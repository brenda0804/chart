# 한국투자증권(KIS) Open API 인증 정보
# 이 파일을 복사해서 .env 로 만들고 실제 값을 채우세요:  cp .env.example .env
# .env 는 .gitignore 에 의해 git 에 올라가지 않습니다.

# KIS 개발자센터에서 발급받은 앱 키/시크릿
KIS_APP_KEY=여기에_APP_KEY
KIS_APP_SECRET=여기에_APP_SECRET

# 계좌번호 (실시간 시세만 쓸 경우 없어도 됨, 주문/잔고 조회 시 필요)
KIS_ACCOUNT_NO=

# 실전(prod) / 모의(vps) 구분
# prod = 실전투자, vps = 모의투자
KIS_ENV=vps

# Supabase (클라우드 DB — 관심종목/메모/1분봉 저장)
# 대시보드 Settings → API 에서 Project URL, Settings → API Keys 에서 Secret key
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_KEY=sb_secret_...
